# =========================
# 1. Python 运行环境与缓存
# =========================
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# =========================
# 2. PyCharm 及编辑器配置
# =========================
.idea/
.vscode/

# =========================
# 3. 敏感配置与密钥 
# =========================
.env
# 如果以后有针对本地的覆盖配置，比如 .env.local，也应该忽略
*.env.*

# =========================
# 4. 项目生成的临时数据与文件
# =========================
# 根据你的目录树，明确忽略临时数据目录
temp_data/

# 忽略可能产生的日志文件
logs/
*.log

# =========================
# 5. 本地数据库与存储持久化文件
# =========================
# 虽然你可能连接的是外部或 Docker 部署的 Milvus/Mongo/MinIO
# 但为了防止本地测试时生成这类大文件被误传，建议加上：
data/
*.db
*.sqlite3

# =========================
# 6. 操作系统生成的垃圾文件
# =========================
.DS_Store
Thumbs.db